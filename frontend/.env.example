# FIFA AI Smart Stadium Copilot — Environment Variables
# Copy this file to .env and fill in your keys

# Google Gemini API Key (get from https://makersuite.google.com/app/apikey)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend API URL (for when Django backend is running)
VITE_API_BASE_URL=https://fifa-world-cup-ai-copilot.onrender.com/api/v1
VITE_API_URL=https://fifa-world-cup-ai-copilot.onrender.com/api/v1

# App Environment
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0
